---
interface PostPreview {
  title: string;
  description: string;
  pubDate: Date;
  heroImage: string;
  tags: string[];
  slug: string;
}

interface Props {
  post: PostPreview;
}

const { post } = Astro.props as Props;
const primaryTag = post.tags[0] ?? 'SEO';
const dateLabel = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).format(post.pubDate);
---

<article class="group flex min-h-full flex-col overflow-hidden rounded-lg border border-white/75 bg-white/[0.65] shadow-[0_24px_80px_rgba(239,125,0,0.16)] backdrop-blur-[20px] transition hover:-translate-y-1 hover:border-orange-300 hover:shadow-[0_26px_90px_rgba(239,125,0,0.2)]">
  <a href={`/${post.slug}`} class="block overflow-hidden" aria-label={post.title}>
    <img class="aspect-[4/3] w-full object-cover transition duration-500 group-hover:scale-105" src={post.heroImage} alt={post.title} loading="lazy" decoding="async" />
  </a>

  <div class="flex flex-1 flex-col bg-white/40 p-6">
    <div class="mb-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-bold text-orange-600">
      <span class="inline-flex items-center gap-1">
        <i class="fa-solid fa-calendar" aria-hidden="true"></i>
        <time datetime={post.pubDate.toISOString()}>{dateLabel}</time>
      </span>
      <span class="inline-flex items-center gap-1">
        <i class="fa-solid fa-tag" aria-hidden="true"></i>
        <span>{primaryTag}</span>
      </span>
    </div>

    <h3 class="mb-2 text-lg font-extrabold leading-snug tracking-normal text-[#1F150F] transition group-hover:text-orange-500">
      <a href={`/${post.slug}`}>{post.title}</a>
    </h3>
    <p class="line-clamp-2 text-sm leading-7 text-[#4A3E38]">{post.description}</p>
  </div>
</article>
