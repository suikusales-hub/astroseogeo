---
interface NavItem {
  label: string;
  href: string;
}

interface Props {
  items?: NavItem[];
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  items = [
    { label: '首页', href: '/' },
    { label: 'SEO教程', href: '/seo-tutorial' },
    { label: 'AI搜索', href: '/ai-geo' },
    { label: '案例库', href: '/case-study' },
    { label: '关于', href: '/about' },
  ],
  ctaLabel = '咨询',
  ctaHref = '/contact',
} = Astro.props as Props;

const currentPath = normalizePath(Astro.url?.pathname ?? '/');

function normalizePath(pathname: string) {
  const normalized = pathname.toLowerCase().replace(/\.html$/, '').replace(/\/+$/, '');
  return normalized === '' ? '/' : normalized;
}
---

<header class="site-header">
  <nav class="navbar glass-panel" aria-label="全站导航">
    <div class="navbar-inner">
    <a class="brand" href="/" aria-label="SEO小平首页">
      <img class="brand-mark" src="/images/seo-xiaoping-avatar.jpg" alt="" width="40" height="40" />
      <span class="brand-name">SEO小平</span>
    </a>

    <div class="nav-links desktop-links">
      {items.map((item) => (
        <a
          class:list={['nav-link', normalizePath(item.href) === currentPath && 'is-active']}
          href={item.href}
          aria-current={normalizePath(item.href) === currentPath ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </div>

    <a class="nav-cta desktop-cta" href={ctaHref}>
      <i class="fa-solid fa-paper-plane" aria-hidden="true"></i>
      <span>{ctaLabel}</span>
    </a>

    <details class="mobile-menu">
      <summary aria-label="打开导航菜单">
        <i class="fa-solid fa-bars" aria-hidden="true"></i>
      </summary>
      <div class="mobile-panel glass-panel">
        {items.map((item) => (
          <a
            class:list={['mobile-link', normalizePath(item.href) === currentPath && 'is-active']}
            href={item.href}
            aria-current={normalizePath(item.href) === currentPath ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
        <a class="mobile-cta" href={ctaHref}>
          <i class="fa-solid fa-paper-plane" aria-hidden="true"></i>
          <span>{ctaLabel}</span>
        </a>
      </div>
    </details>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    padding: 0.85rem 0;
  }

  .navbar {
    position: relative;
    width: 100%;
    margin: 0;
    padding: 0 clamp(1rem, 3vw, 2rem);
    border-radius: 0;
  }

  .navbar-inner {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    width: min(1120px, 100%);
    min-height: 4rem;
    margin: 0 auto;
    padding: 0.65rem 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-width: max-content;
    color: var(--color-text);
    font-weight: 800;
    text-decoration: none;
  }

  .brand-mark {
    display: block;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 8px;
    border: 2px solid rgba(255, 255, 255, 0.82);
    background: #fff;
    object-fit: cover;
    box-shadow: 0 12px 30px rgba(239, 125, 0, 0.28);
  }

  .brand-name {
    font-size: 1.05rem;
    letter-spacing: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    flex: 1;
  }

  .nav-link,
  .mobile-link {
    border-radius: 8px;
    color: rgba(31, 21, 15, 0.76);
    font-size: 0.95rem;
    font-weight: 650;
    text-decoration: none;
    transition:
      background 180ms ease,
      color 180ms ease;
  }

  .nav-link {
    padding: 0.7rem 0.9rem;
  }

  .nav-link:hover,
  .nav-link.is-active,
  .mobile-link:hover,
  .mobile-link.is-active {
    background: rgba(239, 125, 0, 0.12);
    color: var(--color-text);
  }

  .nav-cta,
  .mobile-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: 8px;
    background: var(--color-primary);
    color: #fff;
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
    box-shadow: 0 14px 34px rgba(239, 125, 0, 0.24);
  }

  .nav-cta {
    min-height: 2.55rem;
    padding: 0 1rem;
  }

  .mobile-menu {
    display: none;
    margin-left: auto;
  }

  .mobile-menu summary {
    display: grid;
    width: 2.55rem;
    height: 2.55rem;
    place-items: center;
    border-radius: 8px;
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu[open] summary {
    background: rgba(239, 125, 0, 0.12);
  }

  .mobile-panel {
    position: absolute;
    right: 0.65rem;
    top: calc(100% + 0.6rem);
    display: grid;
    width: min(18rem, calc(100vw - 2rem));
    gap: 0.35rem;
    padding: 0.55rem;
    border-radius: 8px;
  }

  .mobile-link {
    padding: 0.85rem 0.9rem;
  }

  .mobile-cta {
    min-height: 2.75rem;
    margin-top: 0.25rem;
  }

  @media (max-width: 820px) {
    .desktop-links,
    .desktop-cta {
      display: none;
    }

    .mobile-menu {
      display: block;
    }

    .navbar {
      padding-inline: clamp(1rem, 5vw, 1.25rem);
    }

    .navbar-inner {
      min-height: 3.75rem;
    }
  }
</style>
