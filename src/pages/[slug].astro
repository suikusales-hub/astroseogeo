---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArticleSidebar from '../components/ArticleSidebar.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { POST_CATEGORIES } from '../data/categories';
import { toPostSlug } from '../lib/slug';

type PostEntry = CollectionEntry<'posts'>;

interface Props {
  post: PostEntry;
  slug: string;
}

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const usedSlugs = new Map<string, string>();

  return posts.map((post) => {
    const slug = toPostSlug(post.id);

    if (!slug) {
      throw new Error(`Post "${post.id}" must contain at least one lowercase English letter or number for its URL.`);
    }

    const existingEntry = usedSlugs.get(slug);

    if (existingEntry) {
      throw new Error(`Posts "${existingEntry}" and "${post.id}" generate the same URL slug "${slug}".`);
    }

    usedSlugs.set(slug, post.id);

    return {
      params: { slug },
      props: { post, slug },
    };
  });
}

const { post, slug } = Astro.props as Props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, heroImage, tags } = post.data;
const canonicalUrl = `/${slug}`;
const publishedIso = pubDate.toISOString();
const updatedIso = updatedDate.toISOString();
const allPosts = await getCollection('posts');
const sidebarGroups = POST_CATEGORIES.map((category) => ({
  slug: category.slug,
  name: category.name,
  posts: allPosts
    .filter((entry) => entry.data.category === category.slug)
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    .slice(0, 10)
    .map((entry) => ({
      title: entry.data.title,
      slug: toPostSlug(entry.id),
    })),
}));

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  }).format(date);
}
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  image={heroImage}
  schemaType="BlogPosting"
  datePublished={publishedIso}
  dateModified={updatedIso}
  keywords={tags}
>
  <div class="article-layout">
    <article class="article-shell glass-panel">
      <header class="article-header">
        <p class="article-kicker">SEO小平</p>
        <h1>{title}</h1>
        <p class="article-description">{description}</p>

        <div class="article-meta" aria-label="文章信息">
          <time datetime={publishedIso}>发布于 {formatDate(pubDate)}</time>
          <span aria-hidden="true">/</span>
          <time datetime={updatedIso}>更新于 {formatDate(updatedDate)}</time>
        </div>

        <div class="tag-list" aria-label="文章标签">
          {tags.map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
      </header>

      <img class="hero-image" src={heroImage} alt={title} loading="eager" decoding="async" />

      <div class="article-content">
        <Content />
      </div>
    </article>

    <ArticleSidebar groups={sidebarGroups} />
  </div>
</BaseLayout>

<style>
  .article-layout {
    display: grid;
    gap: 2rem;
    align-items: start;
  }

  .article-shell {
    display: grid;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    padding: clamp(1.25rem, 4vw, 3rem);
    border-radius: 8px;
  }

  .article-header {
    display: grid;
    gap: 1rem;
  }

  .article-kicker {
    margin: 0;
    color: var(--color-primary);
    font-size: 0.92rem;
    font-weight: 850;
  }

  h1 {
    max-width: 13ch;
    margin: 0;
    color: var(--color-text);
    font-size: 4.25rem;
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .article-description {
    max-width: 44rem;
    margin: 0;
    color: rgba(31, 21, 15, 0.72);
    font-size: 1.14rem;
    line-height: 1.9;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    color: rgba(31, 21, 15, 0.56);
    font-size: 0.94rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .tag-list span {
    border: 1px solid rgba(239, 125, 0, 0.18);
    border-radius: 8px;
    background: rgba(239, 125, 0, 0.1);
    color: var(--color-text);
    font-size: 0.86rem;
    font-weight: 750;
    line-height: 1;
    padding: 0.48rem 0.65rem;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    object-fit: cover;
    box-shadow: 0 24px 70px rgba(31, 21, 15, 0.12);
  }

  .article-content {
    max-width: 46rem;
    color: rgba(31, 21, 15, 0.86);
    font-size: 1.04rem;
    line-height: 1.95;
  }

  .article-content :global(*) {
    scroll-margin-top: 6rem;
  }

  .article-content :global(p),
  .article-content :global(ul),
  .article-content :global(ol),
  .article-content :global(blockquote),
  .article-content :global(pre),
  .article-content :global(table) {
    margin: 1.1rem 0;
  }

  .article-content :global(h2),
  .article-content :global(h3),
  .article-content :global(h4) {
    color: var(--color-text);
    font-weight: 850;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .article-content :global(h2) {
    margin: 2.3rem 0 0.9rem;
    font-size: 2.05rem;
  }

  .article-content :global(h3) {
    margin: 1.8rem 0 0.75rem;
    font-size: 1.35rem;
  }

  .article-content :global(a) {
    color: var(--color-primary);
    font-weight: 750;
    text-decoration-thickness: 0.08em;
  }

  .article-content :global(strong) {
    color: var(--color-text);
    font-weight: 850;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: 1.35rem;
  }

  .article-content :global(li + li) {
    margin-top: 0.45rem;
  }

  .article-content :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    border-radius: 8px;
    background: rgba(239, 125, 0, 0.08);
    color: rgba(31, 21, 15, 0.76);
    padding: 0.85rem 1rem;
  }

  .article-content :global(code) {
    border-radius: 6px;
    background: rgba(31, 21, 15, 0.08);
    color: var(--color-text);
    font-size: 0.9em;
    padding: 0.15rem 0.35rem;
  }

  .article-content :global(pre) {
    overflow-x: auto;
    border-radius: 8px;
    background: #1f150f;
    color: #fff7ed;
    padding: 1rem;
  }

  .article-content :global(pre code) {
    background: transparent;
    color: inherit;
    padding: 0;
  }

  .article-content :global(img) {
    border-radius: 8px;
  }

  @media (max-width: 680px) {
    h1 {
      max-width: 100%;
      font-size: 2.35rem;
    }

    .article-shell {
      padding: 1rem;
    }

    .article-description {
      font-size: 1rem;
    }

    .article-content :global(h2) {
      font-size: 1.55rem;
    }
  }

  @media (min-width: 1080px) {
    .article-layout {
      grid-template-columns: minmax(0, 1fr) 20rem;
    }

    .article-layout :global(aside) {
      position: sticky;
      top: 6rem;
      max-height: calc(100vh - 7rem);
      overflow: auto;
    }
  }
</style>
